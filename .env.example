# ─── Required ────────────────────────────────────────────────────────
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# ─── Identity ────────────────────────────────────────────────────────
# Name the assistant responds to (used as @trigger in chats)
# ASSISTANT_NAME=Maratai

# ─── Containers ──────────────────────────────────────────────────────
# Container image to use for agents
# CONTAINER_IMAGE=nanoclaw-agent:latest

# Hard timeout per container run (ms). The actual timeout is
# max(CONTAINER_TIMEOUT, IDLE_TIMEOUT + 30s) to allow graceful shutdown.
# CONTAINER_TIMEOUT=1800000

# Max stdout/stderr captured per container run (bytes)
# CONTAINER_MAX_OUTPUT_SIZE=10485760

# How long to keep a container alive after its last output (ms)
# IDLE_TIMEOUT=1800000

# Max containers running at the same time
# MAX_CONCURRENT_CONTAINERS=5

# ─── Polling & Scheduling ───────────────────────────────────────────
# Main message-polling interval (ms)
# POLL_INTERVAL=2000

# How often the task scheduler checks for due tasks (ms)
# SCHEDULER_POLL_INTERVAL=60000

# How often the IPC watcher scans for new files (ms)
# IPC_POLL_INTERVAL=1000

# ─── Retry ───────────────────────────────────────────────────────────
# Max consecutive retries for a failed container before dropping messages
# MAX_RETRIES=5

# Base delay for exponential backoff on retries (ms)
# BASE_RETRY_MS=5000

# ─── Mounts ──────────────────────────────────────────────────────────
# Host directory mounted into main group containers at /workspace/extra/projects.
# Leave empty to skip. Example: /home/user/work/projects
# EXTRA_PROJECTS_DIR=

# ─── Timezone ────────────────────────────────────────────────────────
# Timezone for scheduled tasks. Defaults to system timezone.
# TZ=America/New_York

# ─── Logging ─────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal
# LOG_LEVEL=info
